STOCKTRACE_ENVIRONMENT=development
STOCKTRACE_DEBUG=true
STOCKTRACE_APP__NAME=StockTrace
STOCKTRACE_APP__VERSION=0.1.0
STOCKTRACE_API__HOST=0.0.0.0
STOCKTRACE_API__PORT=8000
STOCKTRACE_API__CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
STOCKTRACE_DATABASE__URL=sqlite+aiosqlite:///./data/stocktrace.db
STOCKTRACE_DATABASE__ECHO=false
STOCKTRACE_REDIS__URL=redis://localhost:6379/0
STOCKTRACE_TELEGRAM__BOT_TOKEN=replace-me
STOCKTRACE_TELEGRAM__CHAT_ID=replace-me
STOCKTRACE_TELEGRAM__ALLOWED_USER_IDS=[]
STOCKTRACE_TELEGRAM__POLLING_ENABLED=true
STOCKTRACE_TELEGRAM__DROP_PENDING_UPDATES=true
STOCKTRACE_SECURITY__API_KEY=replace-me
STOCKTRACE_SECURITY__API_KEY_HEADER=X-API-Key
STOCKTRACE_SECURITY__RATE_LIMIT_PER_MINUTE=120
STOCKTRACE_PROVIDERS__REQUEST_TIMEOUT_SECONDS=10
STOCKTRACE_PROVIDERS__MAX_RETRIES=3
